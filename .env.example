# Copy to .env and fill in for local or production (Render / Railway dashboard)

PORT=3000
HOST=0.0.0.0

# Public site URL (no trailing slash)
# Render backend: your Render app URL
# Live site (Netlify + Hostinger domain)
PUBLIC_URL=https://www.christmissionschool.com

# Netlify build env — your Render API URL (no trailing slash)
# BACKEND_URL=https://christ-mission-school.onrender.com

# Razorpay (https://dashboard.razorpay.com) — Test/Live keys from Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# Legacy SIB gateway (optional, not used if Razorpay is configured)
SIB_MERCHANT_ID=YOUR_MERCHANT_ID
SIB_WORKING_KEY=YOUR_WORKING_KEY
SIB_ACCESS_CODE=YOUR_ACCESS_CODE
SIB_REDIRECT_URL=https://www.christmissionschool.com/api/payment/callback
